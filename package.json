{
  "name": "example-claim-check",
  "version": "0.1.0",
  "description": "Verifiable Claim-Check Assistant — on-device Gemma 4 inference with cryptographic model attestation via Lemma",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "bin": {
    "claim-check": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "dotenv -- tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "tamper": "tsx scripts/tamper.ts",
    "tamper:attribute": "tsx scripts/tamper.ts --mode attribute",
    "tamper:both": "tsx scripts/tamper.ts --mode both",
    "untamper": "tsx scripts/tamper.ts --restore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "poseidon-lite": "^0.3.0",
    "react": "^18.3.1",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@lemmaoracle/sdk": "^0.0.31",
    "@lemmaoracle/spec": "^0.0.30",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}

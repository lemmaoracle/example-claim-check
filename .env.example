# example-claim-check — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored;
# never commit real credentials.

# --- Ollama (local model runtime) ---
# Ollama daemon endpoint.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Model tag to attest and run. Must have a matching entry in
# config/known-good-hashes.json.
OLLAMA_MODEL=gemma4:latest

# --- Lemma workers REST API ---
# Base URL of the Lemma workers deployment. The default points at the public
# deployment, so this can normally be left as-is.
LEMMA_API_BASE=https://workers.lemma.workers.dev
# API key for the Lemma workers backend. Required for the Prove step
# (POST /v1/documents, /v1/proofs). Without it, Attest and Infer still run and
# Prove reports a 401 — or run `pnpm dev --offline` to skip Prove entirely.
LEMMA_API_KEY=

# --- Pinata (IPFS pinning for circuit artifacts) ---
# Required by `npx tsx scripts/register-circuit.ts` to upload compiled
# .wasm and .zkey files to IPFS. Not needed for the daily demo flow.
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
